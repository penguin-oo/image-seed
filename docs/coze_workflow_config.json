{
  "project": "Image Seed 摄影创作研究助手",
  "platform": "Coze / 扣子",
  "localRuntimeUsesExternalApi": false,
  "cozeModelNode": "扣子自带大模型节点",
  "workflowName": "摄影创作研究助手 Image Seed Workflow",
  "description": "用户填写摄影主题、地点、对象、器材、风格、周期和交付形式后，工作流通过扣子自带大模型节点生成摄影项目策划方案，再查询摄影师库和摄影书库，最后整合结果、保存历史并提供收藏入口。本地网页采用同结构规则模拟，不写入外部 API Key。",
  "inputs": [
    {
      "name": "theme",
      "type": "string",
      "required": true,
      "example": "家庭记忆",
      "description": "摄影创作主题"
    },
    {
      "name": "location",
      "type": "string",
      "required": false,
      "example": "老小区和家中客厅",
      "description": "拍摄地点"
    },
    {
      "name": "subject",
      "type": "string",
      "required": false,
      "example": "家人、旧物和居住空间",
      "description": "拍摄对象"
    },
    {
      "name": "gear",
      "type": "string",
      "required": false,
      "example": "手机和微单",
      "description": "拍摄器材"
    },
    {
      "name": "style",
      "type": "string",
      "required": false,
      "example": "家庭档案 / 纪实",
      "description": "影像风格"
    },
    {
      "name": "duration",
      "type": "string",
      "required": false,
      "example": "3天",
      "description": "拍摄周期"
    },
    {
      "name": "deliverable",
      "type": "string",
      "required": false,
      "example": "课程作业组图",
      "description": "最终交付形式"
    },
    {
      "name": "username",
      "type": "string",
      "required": false,
      "example": "student01",
      "description": "用于历史记录和收藏归属"
    }
  ],
  "nodes": [
    {
      "id": "start",
      "type": "start",
      "name": "开始",
      "outputs": ["theme", "location", "subject", "gear", "style", "duration", "deliverable", "username"]
    },
    {
      "id": "coze_model_planner",
      "type": "llm",
      "name": "扣子自带大模型节点 - 摄影项目策划",
      "input": {
        "theme": "{{theme}}",
        "location": "{{location}}",
        "subject": "{{subject}}",
        "gear": "{{gear}}",
        "style": "{{style}}",
        "duration": "{{duration}}",
        "deliverable": "{{deliverable}}"
      },
      "prompt": "你是摄影创作研究助手 Image Seed。请根据用户填写的摄影项目 brief，生成适合课程作业和真实拍摄执行的摄影创作研究方案。必须包含项目标题、创作概念、三个创作方向、至少四条拍摄建议、视觉元素、呈现方式、拍摄日程、12 张成片清单、风险提醒、现场工具包。语言专业但易懂，计划必须具体可执行，不要空泛。",
      "output": "analysis"
    },
    {
      "id": "query_photographers",
      "type": "database_query",
      "name": "查询摄影师库",
      "table": "photographers",
      "matchInput": "{{theme}} {{style}} {{subject}}",
      "matchFields": ["style", "keywords", "intro"],
      "limit": 5,
      "output": "photographers"
    },
    {
      "id": "query_books",
      "type": "database_query",
      "name": "查询摄影书库",
      "table": "photo_books",
      "matchInput": "{{theme}} {{style}} {{subject}}",
      "matchFields": ["title", "theme", "intro"],
      "limit": 5,
      "output": "books"
    },
    {
      "id": "merge_result",
      "type": "code_or_transform",
      "name": "整合研究结果",
      "input": ["analysis", "photographers", "books"],
      "output": "research_result"
    },
    {
      "id": "save_history",
      "type": "database_insert",
      "name": "保存历史记录",
      "table": "history_records",
      "fields": ["username", "keyword", "project_brief", "ai_result", "created_at"]
    },
    {
      "id": "end",
      "type": "end",
      "name": "输出方案",
      "input": "research_result"
    }
  ],
  "outputSchema": {
    "analysis": {
      "title": "string",
      "concept": "string",
      "directions": ["string"],
      "shootingAdvice": ["string"],
      "visualElements": ["string"],
      "presentation": "string",
      "schedule": [
        {
          "day": "string",
          "task": "string",
          "detail": "string"
        }
      ],
      "shotList": [
        {
          "id": "number",
          "name": "string",
          "brief": "string"
        }
      ],
      "risks": ["string"],
      "fieldKit": ["string"]
    },
    "photographers": [
      {
        "name": "string",
        "country": "string",
        "style": "string",
        "intro": "string"
      }
    ],
    "books": [
      {
        "title": "string",
        "author": "string",
        "theme": "string",
        "intro": "string"
      }
    ]
  },
  "cozeLoginStatus": "已尝试使用用户提供的 www.coze.cn cookie 进入 Coze；可访问开放平台 Playground，点击创建资源时跳转火山引擎登录，需要账号二次登录后才能在画布中实际保存工作流。"
}
